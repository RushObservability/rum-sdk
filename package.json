{
  "name": "@rushobservability/rum-sdk",
  "version": "0.2.0",
  "description": "Rush RUM (Real User Monitoring) browser SDK",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RushObservability/rum-sdk.git"
  },
  "homepage": "https://github.com/RushObservability/rum-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/rush-rum.global.js",
  "jsdelivr": "dist/rush-rum.global.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "web-vitals": "^4.2.0"
  },
  "optionalDependencies": {
    "rrweb": "^2.0.0-alpha.20"
  },
  "devDependencies": {
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
